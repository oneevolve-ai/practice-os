generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model TravelRequest {
  id            String       @id @default(cuid())
  title         String
  travelerName  String
  originCity    String?
  destination   String
  departureDate DateTime
  departureTime String?
  returnDate    DateTime
  returnTime    String?
  travelMode    TravelMode   @default(FLIGHT)
  purpose       String
  status        TravelStatus @default(DRAFT)
  estimatedCost Float        @default(0)
  selectedOffer Json?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  statusHistory StatusHistory[]
  attachments   Attachment[]
  legs          TripLeg[]
}

model StatusHistory {
  id         String        @id @default(cuid())
  requestId  String
  request    TravelRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fromStatus TravelStatus?
  toStatus   TravelStatus
  comment    String?
  changedBy  String        @default("System")
  changedAt  DateTime      @default(now())
}

model Attachment {
  id         String        @id @default(cuid())
  requestId  String
  request    TravelRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fileName   String
  filePath   String
  fileSize   Int
  uploadedAt DateTime      @default(now())
}

model TripLeg {
  id            String        @id @default(cuid())
  requestId     String
  request       TravelRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  legOrder      Int
  origin        String
  destination   String
  departureDate DateTime
  departureTime String?
  arrivalDate   DateTime
  arrivalTime   String?
  travelMode    TravelMode    @default(FLIGHT)
  estimatedCost Float         @default(0)
}

enum TravelStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum TravelMode {
  FLIGHT
  TRAIN
  BUS
  CAR
  OTHER
}

// ==================== PEOPLE MODULE ====================

model Department {
  id          String     @id @default(cuid())
  name        String
  code        String     @unique
  description String?
  headId      String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

model Employee {
  id               String         @id @default(cuid())

  // Basic / Official
  name             String
  photo            String?
  email            String         @unique
  personalEmail    String?
  phone            String?
  personalMobile   String?
  linkedin         String?
  designation      String?
  roleDescription  String?
  departmentId     String?
  department       Department?    @relation(fields: [departmentId], references: [id])
  reportingOffice  String?
  reportingManagerId String?
  reportingManager String?
  hrLead           String?

  // Dates
  joiningDate      DateTime?
  dateOfBirth      DateTime?
  resignationDate  DateTime?

  // Status
  status           EmployeeStatus @default(ACTIVE)
  exitType         ExitType?

  // Experience & Education
  yearsOfExperience Float?
  highestQualification String?
  previousOrganisations String?
  orientation      String?

  // AEC Profile
  projectRole      ProjectRole    @default(OTHER)
  scopeExpertise   String?
  projectTypeExpertise String?
  scopeStageExpertise  String?
  licenseNumbers   String?
  isPE             Boolean        @default(false)
  isRA             Boolean        @default(false)

  // Personal / HR
  address          String?
  salaryBand       String?
  emergencyContact String?
  emergencyPhone   String?

  // ID Documents
  aadharNumber     String?
  passportNumber   String?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  leaveRequests    LeaveRequest[]
  attendance       Attendance[]
  documents        EmployeeDocument[]
  regularizationRequests RegularizationRequest[]
}

model EmployeeDocument {
  id         String       @id @default(cuid())
  employeeId String
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  docType    DocType
  fileName   String
  filePath   String
  fileSize   Int
  uploadedAt DateTime     @default(now())
}

enum DocType {
  PHOTO
  CV
  EXPERIENCE_DOC
  EDUCATIONAL_DOC
  EXIT_DOC
  ID_DOC
  OTHER
}

enum ExitType {
  RESIGNATION
  TERMINATION
  RETIREMENT
  CONTRACT_END
  OTHER
}

model LeaveRequest {
  id          String      @id @default(cuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType
  halfDayType HalfDayType @default(FULL_DAY)
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedBy  String?
  reviewNote  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime
  checkIn     String?
  checkOut    String?
  status      AttendanceStatus @default(PRESENT)
  workHours   Float?
  notes       String?
  isHoliday   Boolean          @default(false)
  isLeave     Boolean          @default(false)
  lateArrival Boolean          @default(false)
  earlyDepart Boolean          @default(false)
  checkInLat  Float?
  checkInLng  Float?
  checkInLocation String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  regularizationRequests RegularizationRequest[]

  @@unique([employeeId, date])
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ProjectRole {
  ARCHITECT
  ENGINEER
  CONSULTANT
  PROJECT_MANAGER
  DESIGNER
  OTHER
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  COMP_OFF
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WFH
  ON_LEAVE
}

// ==================== HOLIDAY & POLICY ====================

model Holiday {
  id        String      @id @default(cuid())
  date      DateTime
  name      String
  type      HolidayType @default(NATIONAL)
  year      Int
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([date, name])
}

model LeavePolicy {
  id             String    @id @default(cuid())
  leaveType      LeaveType @unique
  allocation     Int
  carryForward   Boolean   @default(false)
  maxCarryDays   Int       @default(0)
  minAdvanceDays Int       @default(0)
  maxConsecutive Int       @default(0)
  isUnlimited    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model RegularizationRequest {
  id                String               @id @default(cuid())
  employeeId        String
  employee          Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceId      String?
  attendance        Attendance?          @relation(fields: [attendanceId], references: [id])
  date              DateTime
  requestedCheckIn  String?
  requestedCheckOut String?
  reason            String
  status            RegularizationStatus @default(PENDING)
  reviewedBy        String?
  reviewNote        String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

enum HolidayType {
  NATIONAL
  RESTRICTED
  COMPANY
}

enum HalfDayType {
  FULL_DAY
  FIRST_HALF
  SECOND_HALF
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== GEOFENCING & BIOMETRIC ====================

model OfficeLocation {
  id        String   @id @default(cuid())
  name      String
  address   String?
  latitude  Float
  longitude Float
  radius    Int      @default(200) // meters
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BiometricCredential {
  id           String   @id @default(cuid())
  employeeId   String
  credentialId String   @unique
  publicKey    String
  counter      Int      @default(0)
  deviceName   String?
  createdAt    DateTime @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String        @default("default")
  number        String        @unique
  clientName    String
  clientGstin   String?
  clientEmail   String?
  clientAddress String?
  placeOfSupply String?
  invoiceDate   DateTime      @default(now())
  dueDate       DateTime?
  subtotal      Float         @default(0)
  gstRate       Float         @default(18)
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  total         Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  notes         String?
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  hsnCode     String?
  quantity    Float   @default(1)
  unit        String  @default("nos")
  rate        Float
  amount      Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String        @id @default(cuid())
  tenantId    String        @default("default")
  date        DateTime      @default(now())
  category    String
  description String
  amount      Float
  gstAmount   Float         @default(0)
  receiptUrl  String?
  projectName String?
  status      ExpenseStatus @default(PENDING)
  createdAt   DateTime      @default(now())
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

model Client {
  id                String    @id @default(cuid())
  tenantId          String    @default("default")
  name              String
  uin               String?
  businessType      String?
  businessScale     String?
  engagementLevel   String?
  established       Int?
  accountManager    String?
  industry          String?
  website           String?
  linkedIn          String?
  instagram         String?
  email             String?
  phone             String?
  headquarters      String?
  officesInCities   String?
  gstin             String?
  pan               String?
  incorporationCert String?
  bankAccountDetails String?
  companyAnniversary String?
  notes             String?
  status            ClientStatus @default(PROSPECT)
  contacts          Contact[]
  deals             Deal[]
  proposals         ClientProposal[]
  activities        CRMActivity[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Contact {
  id                   String   @id @default(cuid())
  clientId             String
  name                 String
  photo                String?
  designation          String?
  phone                String?
  email                String?
  linkedIn             String?
  instagram            String?
  residentCity         String?
  accountManager       String?
  yearsOfExperience    Int?
  isPrimary            Boolean  @default(false)
  interests            String?
  notes                String?
  birthday             DateTime?
  workAnniversary      DateTime?
  previousOrganisations String?
  educationalInstitutes String?
  createdAt            DateTime @default(now())
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Deal {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  stage       DealStage @default(LEAD)
  value       Float?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model CRMActivity {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  notes     String
  date      DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientProposal {
  id        String   @id @default(cuid())
  clientId  String
  title     String
  value     Float?
  status    String   @default("DRAFT")
  sentDate  DateTime?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CHURNED
}

enum DealStage {
  LEAD
  SHORTLISTED
  PRESENTATION
  PROJECT_DEAL
  PROPOSAL_SENT
  WON
  LOST
  ON_HOLD
}
